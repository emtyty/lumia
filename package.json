{
  "name": "lumia",
  "version": "1.2.4",
  "author": "emtyty",
  "description": "A cross-platform screen capture, annotation, and sharing tool for Windows and macOS",
  "main": "out/main/index.js",
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "icons": "node build/generate-icons.cjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "electron-vite build && set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win",
    "build:mac": "electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2",
    "fft.js": "^4.0.4",
    "fix-webm-duration": "^1.0.6",
    "koffi": "^2.16.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "koffi"
    ]
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "dotenv": "^17.4.0",
    "electron": "^33.4.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "konva": "^9.3.0",
    "png2icons": "^2.0.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-konva": "^18.2.10",
    "react-router-dom": "^6.26.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.5.0",
    "use-image": "^1.1.1"
  }
}
