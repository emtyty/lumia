# Cloudflare R2 — baked into the app at build time, never shown to users
# Account ID: dash.cloudflare.com → R2 Object Storage → Account ID (top-right)
MAIN_VITE_R2_ACCOUNT_ID=
# R2 API Token: R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
MAIN_VITE_R2_ACCESS_KEY_ID=
MAIN_VITE_R2_SECRET_ACCESS_KEY=
# Default bucket name
MAIN_VITE_R2_BUCKET=
# Public base URL for shareable links (r2.dev subdomain or custom domain)
# e.g. https://pub-xxxxxxxxxxxxxxxx.r2.dev
MAIN_VITE_R2_PUBLIC_URL=

# Google Drive OAuth credentials
MAIN_VITE_GDRIVE_CLIENT_ID=
MAIN_VITE_GDRIVE_CLIENT_SECRET=
